{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "theme": "catppuccin",
  "evolution": {
    "enabled": true,
    "directions": [
      "AI",
      "code generation",
      "agent systems",
      "Self-evolution",
      "Long-range consistency"
    ],
    "sources": ["search", "arxiv", "github"],
    "maxItemsPerRun": 10,
    "cooldownHours": 24
  },
  "experimental": {
    "openTelemetry": true,
    "batch_tool": false,
    "mcp_timeout": 60000
  }
}