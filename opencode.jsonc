{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "evolution": {
    "enabled": true,
    "directions": [
      "AI",
      "code generation",
      "agent systems",
      "Self-evolution",
      "Long-range consistency",
      "Code Generation",
      "Agent Systems",
      "RAG",
      "Function Calling",
      "Multi-agent Collaboration",
      "Memory Systems",
      "Benchmark Evaluation",
      "Self-improving",
      "Context Management",
      "Code Understanding",
      "RLHF",
      "DPO"
    ],
    "sources": ["search", "arxiv", "github", "pypi", "blogs"],
    "maxItemsPerRun": 10,
    "cooldownHours": 24
  },
  "experimental": {
    "openTelemetry": true,
    "batch_tool": false,
    "mcp_timeout": 60000
  },
    "embedding": {
      "provider": "dashscope",
      "model": "text-embedding-v4",
      "apiKey": "sk-391a1bcf03e04b55961d15d34de937b2"
    }
}
