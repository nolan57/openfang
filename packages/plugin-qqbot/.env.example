# QQBot Environment Variable Configuration Example
# Copy this file to ~/.local/share/opencode/config/.env or .env in project root

# ==================== Basic Configuration (Required) ====================

# Enable QQBot
QQBOT_ENABLED=true

# QQ Bot App ID (get from https://bot.q.qq.com/)
QQBOT_APP_ID=your_app_id_here

# QQ Bot Client Secret
QQBOT_CLIENT_SECRET=your_client_secret_here

# ==================== Access Control (Optional) ====================

# DM Message Policy: pairing | allowlist | open | disabled
# pairing - Requires pairing code
# allowlist - Only allowed users
# open - Allow all users
# disabled - Disable DM
QQBOT_DM_POLICY=pairing

# Group Message Policy: pairing | allowlist | open | disabled
QQBOT_GROUP_POLICY=allowlist

# Allowed user/group ID list (comma-separated)
# Example: user123,user456,group789
QQBOT_ALLOW_FROM=*

# ==================== Response Configuration (Optional) ====================

# Response Mode: streaming | blocking
# streaming - Streaming response (recommended)
# blocking - Send after complete response
QQBOT_RESPONSE_MODE=streaming

# Streaming Response Delay (milliseconds)
QQBOT_STREAMING_DELAY_MS=300

# Streaming Response Minimum Chunk Size (characters)
QQBOT_STREAMING_MIN_CHUNK=200

# ==================== Voice Features (Optional) ====================

# Enable Voice Messages (TTS)
QQBOT_ENABLE_VOICE=true

# TTS Voice
# Available options: zh-CN-XiaoxiaoNeural, zh-CN-YunxiNeural, zh-CN-YunjianNeural, etc.
# Full list: https://speech.microsoft.com/portal/voicegallery
QQBOT_TTS_VOICE=zh-CN-XiaoxiaoNeural

# Enable Speech-to-Text (STT)
QQBOT_ENABLE_STT=true

# ==================== Media Features (Optional) ====================

# Enable Video Messages
QQBOT_ENABLE_VIDEO=true

# Enable File Messages
QQBOT_ENABLE_FILE=true

# Enable "Typing..." Indicator
QQBOT_ENABLE_TYPING=true

# ==================== Advanced Configuration (Optional) ====================

# Sandbox Mode (for testing)
QQBOT_SANDBOX=false

# Maximum Reconnection Attempts
QQBOT_MAX_RECONNECT_ATTEMPTS=10

# Message Maximum Chunk Size
QQBOT_MAX_CHUNK_SIZE=1500

# ==================== Instructions ====================

# Usage:
# 1. Copy this file to ~/.local/share/opencode/config/.env
# 2. Modify QQBOT_APP_ID and QQBOT_CLIENT_SECRET
# 3. Adjust other configurations as needed
# 4. Restart opencode

# Project-level Configuration:
# Create .env file in project root directory, can override global configuration

# Temporarily Disable QQBot:
# Set QQBOT_ENABLED=false or remove this environment variable
