{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "visual-config.schema.json",
  "title": "Visual Configuration Schema",
  "description": "Schema for visual orchestration engine configuration",
  "type": "object",
  "required": [
    "version",
    "strategy",
    "prompt_engineering",
    "emotions",
    "actions",
    "action_keywords",
    "lighting_presets",
    "styles",
    "atmospheric_effects",
    "negative_prompts",
    "color_palettes",
    "llm",
    "panel_generation",
    "hash"
  ],
  "properties": {
    "version": {
      "type": "string",
      "description": "Configuration version"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "description": { "type": "string" },
        "lastUpdated": { "type": "string" },
        "author": { "type": "string" }
      }
    },
    "strategy_layers": {
      "type": "object",
      "properties": {
        "overrides": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "description", "condition", "effects"],
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" },
              "condition": {
                "type": "object",
                "properties": {
                  "story_tension": {
                    "type": "object",
                    "properties": {
                      "min": { "type": "number" },
                      "max": { "type": "number" }
                    }
                  },
                  "active_motifs": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              },
              "effects": {
                "type": "object",
                "properties": {
                  "camera": { "type": "object", "additionalProperties": true },
                  "lighting": {
                    "oneOf": [{ "type": "string" }, { "type": "object", "additionalProperties": true }]
                  },
                  "composition": { "type": "string" },
                  "atmospheric_effects": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "style": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "negative_prompts_add": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "color_scheme": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "color_temperature": { "type": "string" },
                  "depth_of_field": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "thematic_mappings": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "color_scheme": {
            "type": "array",
            "items": { "type": "string" }
          },
          "lighting_style": { "type": "string" },
          "composition": { "type": "string" },
          "color_temperature": { "type": "string" },
          "depth_of_field": { "type": "string" },
          "style": {
            "type": "array",
            "items": { "type": "string" }
          },
          "atmospheric_effects": {
            "type": "array",
            "items": { "type": "string" }
          },
          "priority_weight": { "type": "number" }
        }
      }
    },
    "strategy": {
      "type": "object",
      "required": ["llm_threshold"],
      "properties": {
        "llm_threshold": {
          "type": "object",
          "required": [
            "complex_emotions",
            "complex_actions",
            "complex_style_patterns",
            "description_length_threshold",
            "use_llm_for_continuity",
            "min_previous_panels_for_continuity"
          ],
          "properties": {
            "complex_emotions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "complex_actions": {
              "type": "array",
              "items": { "type": "string" }
            },
            "complex_style_patterns": {
              "type": "array",
              "items": { "type": "string" }
            },
            "description_length_threshold": { "type": "number" },
            "use_llm_for_continuity": { "type": "boolean" },
            "min_previous_panels_for_continuity": { "type": "number" }
          }
        }
      }
    },
    "prompt_engineering": {
      "type": "object",
      "required": [
        "max_token_limit",
        "token_estimation_factor",
        "priority_weights",
        "priority_keywords",
        "quality_suffix"
      ],
      "properties": {
        "max_token_limit": { "type": "number" },
        "token_estimation_factor": { "type": "number" },
        "priority_weights": {
          "type": "object",
          "required": ["subject_action", "camera_lighting", "style_atmosphere", "background"],
          "properties": {
            "subject_action": { "type": "number" },
            "camera_lighting": { "type": "number" },
            "style_atmosphere": { "type": "number" },
            "background": { "type": "number" }
          }
        },
        "priority_keywords": {
          "type": "object",
          "required": ["subject_action", "camera_lighting", "style_atmosphere", "background"],
          "properties": {
            "subject_action": {
              "type": "array",
              "items": { "type": "string" }
            },
            "camera_lighting": {
              "type": "array",
              "items": { "type": "string" }
            },
            "style_atmosphere": {
              "type": "array",
              "items": { "type": "string" }
            },
            "background": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "quality_suffix": { "type": "string" }
      }
    },
    "emotions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["expression", "bodyLanguage", "facialFeatures"],
        "properties": {
          "expression": { "type": "string" },
          "bodyLanguage": { "type": "string" },
          "facialFeatures": { "type": "string" }
        }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["camera", "lighting", "composition"],
        "properties": {
          "camera": {
            "type": "object",
            "properties": {
              "shot": { "type": "string" },
              "angle": { "type": "string" },
              "movement": { "type": "string" },
              "depthOfField": { "type": "string" }
            }
          },
          "lighting": { "type": "string" },
          "composition": { "type": "string" }
        }
      }
    },
    "action_keywords": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "lighting_presets": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "styles": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "style_negatives": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "atmospheric_effects": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "negative_prompts": {
      "type": "object",
      "required": ["base", "quality_suffix", "shot_specific", "movement_specific"],
      "properties": {
        "base": {
          "type": "array",
          "items": { "type": "string" }
        },
        "quality_suffix": { "type": "string" },
        "shot_specific": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "movement_specific": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "conflict_groups": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "color_palettes": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "weather_palettes": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "llm": {
      "type": "object",
      "required": ["enabled", "temperature", "timeout_ms", "min_confidence_score", "system_prompt", "response_schema"],
      "properties": {
        "enabled": { "type": "boolean" },
        "temperature": { "type": "number" },
        "timeout_ms": { "type": "number" },
        "min_confidence_score": { "type": "number" },
        "system_prompt": { "type": "string" },
        "response_schema": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "panel_generation": {
      "type": "object",
      "required": ["default_count", "min_count", "max_count", "sentence_split_pattern", "min_sentence_length"],
      "properties": {
        "default_count": { "type": "number" },
        "min_count": { "type": "number" },
        "max_count": { "type": "number" },
        "llm_driven": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "fallback_on_error": { "type": "boolean" },
            "timeout_ms": { "type": "number" },
            "temperature": { "type": "number" },
            "complexity_thresholds": {
              "type": "object",
              "properties": {
                "min_sentences_for_multi_panel": { "type": "number" },
                "action_scene_bonus": { "type": "number" },
                "emotional_scene_bonus": { "type": "number" },
                "dialogue_scene_reduction": { "type": "number" }
              }
            },
            "scene_complexity_patterns": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "sentence_split_pattern": { "type": "string" },
        "min_sentence_length": { "type": "number" }
      }
    },
    "continuity": {
      "type": "object",
      "properties": {
        "llm_analysis": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "temperature": { "type": "number" },
            "focus_areas": {
              "type": "array",
              "items": { "type": "string" }
            },
            "outfit_change_triggers": {
              "type": "object",
              "properties": {
                "high_confidence": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "low_confidence": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        },
        "prompt_enhancement": {
          "type": "object",
          "properties": {
            "consistency_keywords": {
              "type": "array",
              "items": { "type": "string" }
            },
            "max_previous_panels": { "type": "number" }
          }
        }
      }
    },
    "hash": {
      "type": "object",
      "required": ["algorithm", "version", "initial_value"],
      "properties": {
        "algorithm": { "type": "string" },
        "version": { "type": "string" },
        "initial_value": { "type": "number" }
      }
    }
  }
}
