    "comic": ["comic book style", "bold outlines", "saturated colors", "dynamic panel"],
    "noir": ["film noir", "high contrast black and white", "dramatic shadows", "moody"],
    "cyberpunk": ["cyberpunk aesthetic", "neon lights", "futuristic", "high tech low life"],
    "fantasy": ["fantasy art", "magical elements", "epic composition", "detailed environment"],
    "horror": ["horror atmosphere", "dark and eerie", "gothic", "disturbing details"],
