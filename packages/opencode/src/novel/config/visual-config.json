      "static": ["lifeless", "stiff", "unnatural stillness"],
      "track": ["motion blur artifact", "speed lines"],
      "dolly": ["distorted edges", "stretching"],
      "steadicam": ["floating hands", "unstable horizon"]
    },
    "conflict_groups": [
      ["warm_tones", "cold_tones", "warm", "cold", "cool"],
      ["bright", "dark", "low_key", "high_key"],
      ["realistic", "abstract", "surreal", "photorealistic"],
      ["centered", "off_center", "symmetrical", "asymmetric"],
