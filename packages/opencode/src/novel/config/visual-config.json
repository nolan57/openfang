    "natural": "soft daylight, warm tones, natural shadows",
    "dramatic": "single light source, high contrast, theatrical shadows",
    "ethereal": "soft glow, misty atmosphere, dreamlike quality",
    "industrial": "harsh fluorescent, cold tones, gritty atmosphere",
