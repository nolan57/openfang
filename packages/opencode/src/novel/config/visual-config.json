{
  "$schema": "./visual-config.schema.json",
  "version": "2.0.0",
  "metadata": {
    "description": "Visual Orchestration Engine Configuration - Dynamic Strategy Edition",
    "lastUpdated": "2026-03-18",
    "author": "Visual Orchestration Architect"
  },

  "strategy_layers": {
    "overrides": [
      {
        "name": "High Tension Override",
        "description": "当故事张力过高时，强制应用手持摄影和高对比度",
        "condition": {
          "story_tension": { "min": 0.8 }
        },
        "effects": {
          "camera": {
            "movement": "handheld",
            "shake_intensity": "high"
          },
          "lighting": {
            "style": "high_contrast",
            "flicker": true
          },
          "negative_prompts_add": ["static_shot", "calm_atmosphere", "smooth_lighting"]
        }
      },
      {
        "name": "Chaos Motif Enhancement",
        "description": "当检测到混沌母题时，增加氛围效果",
        "condition": {
          "active_motifs": ["chaos", "metamorphosis", "supernatural"]
        },
        "effects": {
          "atmospheric_effects": ["smoke", "dust", "volumetric_light"],
          "style": ["surreal", "distorted_perspective"]
        }
      },
      {
        "name": "Isolation Theme",
        "description": "当检测到孤立主题时，应用空旷构图",
        "condition": {
          "active_motifs": ["isolation", "loneliness", "abandonment"]
        },
        "effects": {
          "composition": "rule_of_thirds_empty_space",
          "color_temperature": "cold",
          "depth_of_field": "deep"
        }
      },
      {
        "name": "Light vs Dark Theme",
        "description": "当检测到光明与黑暗对抗主题时，应用明暗对比",
        "condition": {
          "active_motifs": ["light_vs_dark", "good_vs_evil", "moral_conflict"]
        },
        "effects": {
          "lighting": "chiaroscuro",
          "color_scheme": ["#ffffff", "#000000"]
        }
      }
    ]
  },

  "thematic_mappings": {
    "light_vs_dark": {
      "color_scheme": ["#ffffff", "#000000"],
      "lighting_style": "chiaroscuro",
      "priority_weight": 5
    },
    "isolation": {
      "composition": "rule_of_thirds_empty_space",
      "color_temperature": "cold",
      "depth_of_field": "deep"
    },
    "chaos": {
      "composition": "dynamic_imbalance",
      "color_scheme": ["#ff0000", "#000000", "#ffff00"],
      "atmospheric_effects": ["smoke", "dust"]
    },
    "hope": {
      "color_temperature": "warm",
      "lighting_style": "golden_hour",
      "composition": "upward_angle"
    },
    "transformation": {
      "style": ["surreal", "metamorphosis"],
      "atmospheric_effects": ["sparkles", "ethereal_glow"]
    }
  },

  "strategy": {
    "llm_threshold": {
      "description": "Thresholds for deciding when to use LLM vs hardcoded rules",
      "complex_emotions": [
        "existential_dread",
        "bittersweet_nostalgia",
        "manic_joy",
        "melancholic_acceptance",
        "conflicted_love",
        "repressed_anger",
        "quiet_desperation",
        "spiritual_awakening",
        "moral_conflict",
        "existential",
        "bittersweet",
        "manic",
        "melancholic",
        "conflicted",
        "repressed",
        "desperation",
        "spiritual",
        "moral_conflict"
      ],
      "complex_actions": [
        "transformation",
        "metamorphosis",
        "ritual",
        "ceremony",
        "hallucination",
        "dream_sequence",
        "flashback",
        "supernatural",
        "magical",
        "surreal",
        "abstract"
      ],
      "complex_style_patterns": ["\\w+\\s*\\+\\s*\\w+", "blend|fusion|mixed|hybrid", "traditional\\s+\\w+\\s+with\\s+"],
      "description_length_threshold": 150,
      "use_llm_for_continuity": true,
      "min_previous_panels_for_continuity": 1
    }
  },

  "prompt_engineering": {
    "max_token_limit": 75,
    "token_estimation_factor": 0.75,
    "priority_weights": {
      "subject_action": 1,
      "camera_lighting": 2,
      "style_atmosphere": 3,
      "background": 4
    },
    "priority_keywords": {
      "subject_action": ["character", "expression", "body", "pose", "action", "standing", "sitting", "moving"],
      "camera_lighting": ["shot", "camera", "angle", "lighting", "light", "focus", "depth"],
      "style_atmosphere": ["style", "atmosphere", "effect", "mood", "tone", "quality"],
      "background": []
    },
    "quality_suffix": "high quality, detailed, 8k, professional photography"
  },

  "emotions": {
    "joy": {
      "expression": "smiling, eyes crinkled at corners, teeth visible",
      "bodyLanguage": "arms open, shoulders relaxed, upright posture",
      "facialFeatures": "raised eyebrows, dilated pupils, flushed cheeks"
    },
    "hope": {
      "expression": "gentle smile, soft eyes, slight upward gaze",
      "bodyLanguage": "leaning forward, hands open, relaxed stance",
      "facialFeatures": "relaxed forehead, slight furrow of determination"
    },
    "pride": {
      "expression": "confident smile, head held high, chin lifted",
      "bodyLanguage": "chest out, arms on hips or folded, commanding stance",
      "facialFeatures": "arched eyebrows, slight squint, determined look"
    },
    "gratitude": {
      "expression": "warm smile, soft eyes, slightly moist",
      "bodyLanguage": "slight bow, hands clasped, humble posture",
      "facialFeatures": "relaxed features, slight head tilt"
    },
    "love": {
      "expression": "tender smile, soft gaze, eyes focused on subject",
      "bodyLanguage": "leaning toward, gentle touch, open arms",
      "facialFeatures": "relaxed brows, slight blush, gentle expression"
    },
    "anger": {
      "expression": "furrowed brows, narrowed eyes, tight lips",
      "bodyLanguage": "tense shoulders, fists clenched, forward lean, aggressive stance",
      "facialFeatures": "flared nostrils, flushed face, jaw clenched"
    },
    "fear": {
      "expression": "wide eyes, open mouth, pale complexion",
      "bodyLanguage": "cowering, arms raised defensively, recoiling, frozen stance",
      "facialFeatures": "dilated pupils, raised eyebrows, trembling lips"
    },
    "sadness": {
      "expression": "downturned mouth, drooping eyelids, teary eyes",
      "bodyLanguage": "slumped shoulders, head down, arms hanging limply",
      "facialFeatures": "furrowed brow, pale complexion, quivering chin"
    },
    "guilt": {
      "expression": "averted gaze, downcast eyes, tight smile",
      "bodyLanguage": "hunched shoulders, crossed arms, fidgeting, avoidant posture",
      "facialFeatures": "shifty eyes, furrowed brow, nervous expression"
    },
    "shame": {
      "expression": "downcast eyes, blush, hidden face",
      "bodyLanguage": "trying to disappear, crossing arms over chest, head down",
      "facialFeatures": "reddened face, avoiding eye contact, nervous"
    },
    "envy": {
      "expression": "narrowed eyes, tight smile, sneer",
      "bodyLanguage": "arms crossed, rigid posture, leaning away",
      "facialFeatures": "tight jaw, slight curl of lip, hardened gaze"
    },
    "hate": {
      "expression": "contorted features, snarling, intense glare",
      "bodyLanguage": "aggressive stance, pointing finger, towering over",
      "facialFeatures": "flared nostrils, narrowed eyes, twisted mouth"
    },
    "surprise": {
      "expression": "wide eyes, raised eyebrows, open mouth",
      "bodyLanguage": "startled jump, hands raised to face, frozen",
      "facialFeatures": "dilated pupils, raised brows, slack jaw"
    },
    "confusion": {
      "expression": "furrowed brow, squinting eyes, puzzled expression",
      "bodyLanguage": "scratching head, shoulder shrug, hesitant stance",
      "facialFeatures": "tightened lips, tilted head, uncertain gaze"
    }
  },

  "actions": {
    "fight": {
      "camera": { "shot": "medium", "angle": "low", "movement": "handheld", "depthOfField": "shallow" },
      "lighting": "dramatic chiaroscuro, high contrast",
      "composition": "action framing, subject centered, dynamic imbalance"
    },
    "conversation": {
      "camera": { "shot": "over-shoulder", "angle": "eye-level", "movement": "steadicam", "depthOfField": "shallow" },
      "lighting": "soft key light, natural fill",
      "composition": "rule of thirds, dialogue framing"
    },
    "monologue": {
      "camera": { "shot": "close-up", "angle": "eye-level", "movement": "static", "depthOfField": "shallow" },
      "lighting": "motivated rim light, soft shadows",
      "composition": "centered, centered composition"
    },
    "introspection": {
      "camera": { "shot": "extreme-close-up", "angle": "high", "movement": "static", "depthOfField": "shallow" },
      "lighting": "cool tones, low key",
      "composition": "extreme close-up, minimal framing"
    },
    "chase": {
      "camera": { "shot": "medium-wide", "angle": "low", "movement": "track", "depthOfField": "deep" },
      "lighting": "high contrast, motion blur",
      "composition": "leading lines, dynamic framing"
    },
    "revelation": {
      "camera": { "shot": "wide", "angle": "eye-level", "movement": "dolly", "depthOfField": "deep" },
      "lighting": "dramatic reveal, single source spotlight",
      "composition": "centered subject, symmetrical framing"
    },
    "emotional": {
      "camera": { "shot": "close-up", "angle": "eye-level", "movement": "steadicam", "depthOfField": "shallow" },
      "lighting": "soft, warm tones, emotional lighting",
      "composition": "intimate framing, shallow focus"
    },
    "tension": {
      "camera": { "shot": "medium", "angle": "low", "movement": "handheld", "depthOfField": "none" },
      "lighting": "dark, high contrast, tension lighting",
      "composition": "off-center, claustrophobic framing"
    },
    "action": {
      "camera": { "shot": "medium-wide", "angle": "low", "movement": "handheld", "depthOfField": "shallow" },
      "lighting": "high contrast, action lighting",
      "composition": "dynamic framing, motion lines"
    },
    "calm": {
      "camera": { "shot": "wide", "angle": "eye-level", "movement": "steadicam", "depthOfField": "deep" },
      "lighting": "natural soft light, warm tones",
      "composition": "balanced, peaceful framing"
    },
    "mysterious": {
      "camera": { "shot": "medium", "angle": "high", "movement": "static", "depthOfField": "shallow" },
      "lighting": "low key, blue tint, mysterious shadows",
      "composition": "shadowy, ambiguous framing"
    },
    "romantic": {
      "camera": { "shot": "close-up", "angle": "eye-level", "movement": "steadicam", "depthOfField": "shallow" },
      "lighting": "warm golden hour, soft glow, romantic lighting",
      "composition": "soft focus, intimate framing"
    }
  },

